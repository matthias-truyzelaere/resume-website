---
import styles from './Styles.module.css'

interface Props {
    class?: string
}

const { class: className } = Astro.props
---

<section id="experience" class:list={[className, styles.section]}>
    <h2 class={styles.section__heading}>Experience</h2>
    <ol class={styles.experience__list} reversed>
        <li class={styles.experience__item}>
            <h3 class={styles.experience__title}>Logiscool · Teacher</h3>
            <p class={styles.experience__meta}>
                <time datetime="2022-07">July 2022</time> - Present
            </p>
            <p class={styles.experience__description}>Teaching programming and problem-solving to children aged 7-15 in an educational environment, enhancing their critical thinking.</p>
        </li>
        <li class={styles.experience__item}>
            <h3 class={styles.experience__title}>TenX · IT Developer</h3>
            <p class={styles.experience__meta}>
                <time datetime="2025-07">July 2025</time>
            </p>
            <p class={styles.experience__description}>Built an AI-powered tool that generates client reports using Next.js and FastAPI, saving hours of manual documentation per client.</p>
        </li>
        <li class={styles.experience__item}>
            <h3 class={styles.experience__title}>Nyxa Hosting · Founder & CEO</h3>
            <p class={styles.experience__meta}>
                <time datetime="2023-02">February 2023</time> -
                <time datetime="2025-12">December 2025</time>
            </p>
            <p class={styles.experience__description}>Co-founded a hosting business serving 70+ clients across 15+ countries, later pivoted to B2B web development.</p>
        </li>
    </ol>
</section>
